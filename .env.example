# ── Banco de dados ───────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/nahora
DB_USERNAME=nahora
DB_PASSWORD=nahora_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Gere uma chave segura: openssl rand -base64 64
JWT_SECRET=troque_por_uma_chave_de_no_minimo_256_bits_em_producao
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Firebase (push notifications) ───────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Pagar.me ─────────────────────────────────────────────────────────────────
PAGARME_API_KEY=sk_test_...

# ── Storage ───────────────────────────────────────────────────────────────────
# Dev local (MinIO): rode "docker compose up -d" e crie o bucket no console em http://localhost:9001
# Usuário/senha do MinIO: dev / dev12345
STORAGE_BUCKET=nahora-dev
STORAGE_ACCESS_KEY=dev
STORAGE_SECRET_KEY=dev12345
STORAGE_ENDPOINT=http://localhost:9000

# Produção (Cloudflare R2): substitua os valores abaixo e remova as vars acima
# STORAGE_BUCKET=<nome-do-bucket>
# STORAGE_ACCESS_KEY=<R2 Access Key ID>
# STORAGE_SECRET_KEY=<R2 Secret Access Key>
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://nahora.app
